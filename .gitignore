# ==============================
# Local Environment Context
# ==============================
# Exclude machine-specific details (nvcc, drivers, conda config) from Git.
# Note: These are re-included in the LLM context via .repomixignore rules.
.for_ai/*

# Whitelist documentation and example files
!.for_ai/README.md
!.for_ai/nvcc_version.example

# ==============================
# Repomix / Tool Outputs
# ==============================
repomix-output.xml
codebase_context.xml

# ==============================
# C++ / CUDA Build Artifacts
# ==============================
build/
bin/
*.o
*.so
*.a
*.exe
compile_flags.txt

# ==============================
# Python & Environment
# ==============================
__pycache__/
*.py[cod]
venv/
.env
.vscode/*
!.vscode/settings.json

# ==============================
# Data
# ==============================
references/nanogpt_practice/*.txt

# ==============================
# Model Weights
# ==============================
weights/
*.pt
*.pth
*.safetensors
*.bin
*.onnx

# ==============================
# OS Files
# ==============================
.DS_Store

# ==============================
# Local Practice & Temp Files
# ==============================
_TEMPPRAC_*

# ==============================
# Profiling: Nsight Systems & Compute
# ==============================
# Global ignore for profiling artifacts (prevents accidental root commits)
*.nsys-rep
*.ncu-rep
*.sqlite

# Ignore all contents in any 'reports' dir, but keep README placeholders
**/reports/*
!**/reports/README.md

# Ignore downloaded tool installers
downloads/

